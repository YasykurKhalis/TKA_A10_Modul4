{
  "dashboard": {
    "id": null,
    "uid": "gurren-lagann-vitals",
    "title": "Gurren Lagann Vitals",
    "tags": [ "templated" ],
    "timezone": "browser",
    "schemaVersion": 36,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "title": "Spiral Power (CPU Usage)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "title": "Core Integrity (Memory Usage)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "((node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes) * 100",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "title": "Total HTTP Request",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[1m]))",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "overwrite": true
}
